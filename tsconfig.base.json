{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@company/ui": ["packages/ui/src"],
      "@company/shared": ["packages/shared/src"],
      "@company/auth": ["packages/auth/src"],
      "@company/api": ["packages/api/src"]
    }
  }
}
