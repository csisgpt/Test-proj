VITE_API_BASE_URL=http://localhost:4000/api
VITE_API_TIMEOUT=30000
VITE_SSO_ENABLED=true
VITE_SSO_PROVIDER=keycloak
VITE_SSO_CLIENT_ID=company-platform
VITE_SSO_REALM=company
VITE_SSO_BASE_URL=https://sso.company.com
VITE_APP_NAME=Company Platform
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
VITE_FEATURE_PHARMACY=true
VITE_FEATURE_INSURANCE=true
VITE_FEATURE_HOUSING=true
VITE_FEATURE_LOAN=true


# API

