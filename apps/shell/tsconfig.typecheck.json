{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,

    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "types": ["vite/client"],

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@": ["src"],

      "@company/api": ["../../packages/api/dist/index.d.ts"],
      "@company/auth": ["../../packages/auth/dist/index.d.ts"],
      "@company/ui": ["../../packages/ui/dist/index.d.ts"],
      "@company/shared": ["../../packages/shared/dist/index.d.ts"],
      "@company/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"],
  "exclude": ["dist", "node_modules"]
}
