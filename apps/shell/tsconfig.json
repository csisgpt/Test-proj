{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "target": "ES2020",
    "module": "ESNext",                // ⬅️ مهم
    "moduleResolution": "Bundler",     // ⬅️ همراه با ESNext اوکیه
    "jsx": "preserve",
    "types": ["vite/client"],
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"],
  "exclude": ["dist", "node_modules"]
}
